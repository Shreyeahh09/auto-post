APP_ID=
APP_SECRET=
IG_ACCESS_TOKEN=
IG_USER_ID=
# Graph API version used for the facebook.com base + token refresh.
IG_GRAPH_VERSION=v23.0
IG_LOGIN_KIND=ig_login
# OPTIONAL — Facebook Page id + Page access token (needed for Pages + DM tools).
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# OPTIONAL — Meta app credentials (needed for fb_exchange_token refresh + debug_token).
META_APP_ID=
META_APP_SECRET=
OPENAI_API_KEY=
# OPTIONAL — Google Drive service account for local media publishing.
# Create a service account at https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Drive API, download the JSON key file, and set the path below.
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL — Google Drive folder ID to upload media into (keeps things organized).
# Create a folder in Drive, share it with the service account email, and paste the folder ID.
GOOGLE_DRIVE_FOLDER_ID=
