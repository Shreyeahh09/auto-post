APP_ID=
APP_SECRET=
IG_ACCESS_TOKEN=
IG_USER_ID=
# Graph API version used for the facebook.com base + token refresh.
IG_GRAPH_VERSION=v23.0
IG_LOGIN_KIND=ig_login
# OPTIONAL — Facebook Page id + Page access token (needed for Pages + DM tools).
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# OPTIONAL — Meta app credentials (needed for fb_exchange_token refresh + debug_token).
META_APP_ID=
META_APP_SECRET=
OPENAI_API_KEY=
# OPTIONAL — Google Drive service account for local media publishing.
# Create a service account at https://console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Drive API, download the JSON key file, and set the path below.
GOOGLE_SERVICE_ACCOUNT_JSON=

# OPTIONAL — Google Drive folder ID to upload media into (keeps things organized).
# Create a folder in Drive, share it with the service account email, and paste the folder ID.
GOOGLE_DRIVE_FOLDER_ID=

# OPTIONAL — lets customers link their OWN Google Drive (separate from the service account
# above) so the autopilot media queue can pull new photos/videos from a folder they choose.
# Create an OAuth 2.0 "Web application" client at
# https://console.cloud.google.com -> APIs & Services -> Credentials, add the redirect URI
# below as an authorized redirect URI, and paste the client id/secret here.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/google-drive/callback

# REQUIRED — Cloudflare R2 bucket for the customer media queue (manual uploads + Drive
# imports). Customers upload directly to R2 from the browser via a presigned URL; this
# server's process never touches the file bytes.
#   1. https://dash.cloudflare.com -> R2 -> Create bucket
#   2. R2 -> Manage API tokens -> Create API token (permissions: Object Read & Write,
#      scoped to that bucket) -> gives you the access key id/secret below
#   3. R2_ACCOUNT_ID is shown on the R2 overview page (top right of the dashboard)
#   4. Enable public access on the bucket (Settings -> Public access -> either the
#      bucket's r2.dev subdomain, or attach your own custom domain) and set
#      R2_PUBLIC_BASE_URL to that public origin (no trailing slash)
#   5. Settings -> CORS Policy -> allow PUT (and GET) from your dashboard's origin
#      (e.g. http://localhost:8000 in dev, your real domain in production) — required
#      since the browser uploads straight to R2, not through this server
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# ═══════════════════════════════════════════════════════════════════════
# SaaS Platform Configuration (for the multi-tenant dashboard)
# ═══════════════════════════════════════════════════════════════════════

# Supabase project — Project Settings -> API. Auth (admin + customer login/signup)
# and primary data storage both go through this project.
# Base project URL, no /rest/v1 suffix.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# SECRET — server-side only, never expose to the dashboard/frontend.
SUPABASE_SERVICE_ROLE_KEY=

# Fernet encryption key for encrypting Instagram tokens at rest
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Auto-generated if not set, but SAVE IT or you'll lose access to encrypted tokens on restart!
ENCRYPTION_KEY=

# Supabase Postgres connection string — Project Settings -> Database -> Connection
# string -> URI. URL-encode special characters in the password (@ -> %40, etc.)
# since it's embedded directly in the URI.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Server port (Railway/Render set this automatically)
PORT=8000

# Public, internet-reachable base URL of this server (no trailing slash). Used to build
# redirect URLs (e.g. back to the dashboard after the Google Drive OAuth callback). Media is
# served from R2 (see R2_PUBLIC_BASE_URL above), not from this server. Use your real domain
# in production.
PUBLIC_BASE_URL=http://localhost:8000

# OpenAI model used for caption generation (vision-capable; gpt-4o-mini is the cost-effective default).
OPENAI_MODEL=gpt-4o-mini
